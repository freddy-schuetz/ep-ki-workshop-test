# Steuerung des Kreativ-Proxys (nur für den Claude-Code-Weg relevant).
# Beide Variablen haben bereits sinnvolle Defaults in lib/config.ts —
# das Setzen ist OPTIONAL. Es sind KEINE echten Geheimnisse:
#   - PROXY_URL ist eine öffentliche URL
#   - WORKSHOP_TOKEN ist ein kurzlebiges Workshop-Gate (wird nach dem Event rotiert)

PROXY_URL=https://ep-ki-workshop-proxy.vercel.app
WORKSHOP_TOKEN=ep-winter-2026

# Hinweis (Google AI Studio):
# AI Studio fragt diese Variablen ab, weil sie in lib/config.ts via process.env
# vorkommen. Einfach die obigen Werte eintragen — oder ignorieren:
# In AI Studio laufen die Kreativ-Funktionen ohnehin über Geminis eigene
# Bild-/Text-Erzeugung (siehe AGENTS.md), nicht über diesen Proxy.
